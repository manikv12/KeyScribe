{
  "name": "@keyscribe/electron-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "KeyScribe Electron desktop app",
  "author": "KeyScribe",
  "main": "apps/desktop/out/main/index.js",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --filter @keyscribe/desktop dev",
    "build": "pnpm -r build",
    "package:ci": "pnpm build && electron-builder --config electron-builder.yml --publish never",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
